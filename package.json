{
  "name": "nuxt-ui-template-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "db:drift": "prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --exit-code",
    "db:generate": "prisma generate",
    "db:lint": "supabase db lint --local --fail-on error",
    "db:reset": "supabase db reset --local",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:validate": "prisma validate",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "prisma generate && nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "auth:hash": "node scripts/hash-password.mjs"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.86",
    "@internationalized/date": "^3.12.2",
    "@nuxt/ui": "^4.9.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tanstack/table-core": "^8.21.3",
    "@unovis/ts": "^1.6.6",
    "@unovis/vue": "^1.6.6",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.6.0",
    "nuxt": "^4.4.8",
    "pg": "^8.22.0",
    "scule": "^1.3.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.5.0",
    "prisma": "7.8.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.8.0"
}
