# Public application and Supabase Auth configuration.
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SUPABASE_URL=
# Only use the sb_publishable_ key. Never expose sb_secret_ or service_role.
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Siigo API Mexico credentials. Keep these only in .env locally and in Vercel environment variables.
# The Mexico API base is https://api.siigo.mx.
NUXT_SIIGO_API_URL=https://api.siigo.mx
NUXT_SIIGO_USERNAME=
NUXT_SIIGO_ACCESS_KEY=
# 3-100 alphanumeric characters, no spaces. Must identify this integration consistently.
NUXT_SIIGO_APPLICATION_ID=CarolinaPinturas

# PostgreSQL / Supabase.
# Local: both URLs point to the database started by `supabase start`.
# Production: DATABASE_URL should use Supabase's transaction pooler (port 6543)
# and DIRECT_URL should use the direct/session connection for migrations.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres?schema=public
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres?schema=public
