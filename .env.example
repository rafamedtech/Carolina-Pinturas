# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# Authentication for the three internal users. This value signs encrypted session cookies.
# Generate it with: openssl rand -base64 48
NUXT_APP_SESSION_SECRET=

# JSON array of the dashboard users. Keep this entire value on ONE line and wrapped in single quotes.
# Generate a passwordHash with: pnpm auth:hash -- "password"
# Example:
# NUXT_APP_USERS='[{"name":"Administrador","email":"admin@carolinapinturas.mx","role":"admin","passwordHash":"scrypt$..."}]'
NUXT_APP_USERS=[]

# Optional Vercel-safe alternative: base64url of the JSON array above.
# If this is set, it takes precedence over NUXT_APP_USERS.
NUXT_APP_USERS_BASE64=

# Siigo API Mexico credentials. Keep these only in .env locally and in Vercel environment variables.
# The Mexico API base is https://api.siigo.mx.
NUXT_SIIGO_API_URL=https://api.siigo.mx
NUXT_SIIGO_USERNAME=
NUXT_SIIGO_ACCESS_KEY=
# 3-100 alphanumeric characters, no spaces. Must identify this integration consistently.
NUXT_SIIGO_APPLICATION_ID=CarolinaPinturas
